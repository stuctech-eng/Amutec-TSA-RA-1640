{
  "version": 21.7,
  "builds": [
    {
      "src": "api/claude.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/claude",
      "dest": "/api/claude.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/claude.js": {
      "maxDuration": 30
    }
  }
}